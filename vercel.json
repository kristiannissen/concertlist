{
   "$schema":"https://openapi.vercel.sh/vercel.json",
   "framework":null,
   "outputDirectory":"public",
   "trailingSlash":false,
   "cleanUrls":true,
   {
      "services":{
         "go_backend":{
            "root":"/api",
            "entrypoint":"cmd/api"
         }
      }
   },
   "rewrites":[
      {
         "source":"/api/(*.)",
         "destination":{
            "service":"go_backend"
         }
      }
   ]
}
