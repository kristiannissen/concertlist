{
   "$schema":"https://openapi.vercel.sh/vercel.json",
   "framework":null,
   "outputDirectory":"public",
   "regions":["arn1"],
   "rewrites":[
      {
         "source":"/api/(.*)",
         "destination":"/api"
      }
   ],
   "build":{
      "env":{
         "GO_BUILD_FLAGS":"-ldflags '-s -w'"
      }
   },
   "crons":[
      {
         "path":"/api/musicevent/richter",
         "schedule":"0 0 * * *"
      }
   ],
   "functions":{
      "api/queue-consumer.go":{
         "experimentalTriggers":[
            {
               "type":"queue/v2beta",
               "topic":"musicevent",
               "retryAfterSeconds":60,
               "initialDelaySeconds":0
            }
         ]
      }
   }
}
