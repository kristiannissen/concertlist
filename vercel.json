{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [{"source": "/api/(.*)", "destination": "api/index.go"}],
  "headers": [
    {"source": "/(styles\.css|app\.js|sw\.js|manifest\.json|changelog\.json)", "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]},
    {"source": "/", "headers": [{"key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800"}]}
  ],
  "git": {"deploymentEnabled": false}
}