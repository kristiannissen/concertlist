{
   "$schema":"https://openapi.vercel.sh/vercel.json",
   "framework":null,
   "trailingSlash":false,
   "cleanUrls":true,
      "services":{
         "go_backend":{
            "root":"cmd/api/"
         },
	 "frontend": {
		"root": "public/"
	}
      },
   "rewrites":[
      {
         "source":"/api/(*.)",
         "destination":{
            "service":"go_backend"
         },
	 "source": "/(.*)",
	 "destination": {
		"service": "frontend"
	}
      }
   ]
}
