{
   "$schema":"https://openapi.vercel.sh/vercel.json",
   "framework":null,
   "outputDirectory":"public",
   "regions":["arn1"],
   "git":{
      "deploymentEnabled":false
   },
   "rewrites":[
      {
         "source":"/api/queue-consumer",
         "destination":"/api/queue-consumer"
      },
      {
         "source":"/api/queue-extract-consumer",
         "destination":"/api/queue-extract-consumer"
      },
      {
         "source":"/api/(.*)",
         "destination":"/api"
      }
   ],
   "build":{
      "env":{
         "GO_BUILD_FLAGS":"-ldflags '-s -w'"
      }
   },
   "crons":[
      {
         "path":"/api/scrape/trigger",
         "schedule":"0 0 * * *"
      }
   ],
   "functions":{
      "api/queue-consumer/index.go":{
         "experimentalTriggers":[
            {
               "type":"queue/v2beta",
               "topic":"venue-scrape",
               "retryAfterSeconds":60,
               "initialDelaySeconds":0
            }
         ]
      },
      "api/queue-extract-consumer/index.go":{
         "experimentalTriggers":[
            {
               "type":"queue/v2beta",
               "topic":"event-extract",
               "retryAfterSeconds":60,
               "initialDelaySeconds":0
            }
         ]
      }
   }
}
